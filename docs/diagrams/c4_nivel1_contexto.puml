@startuml C4_Nivel1_Contexto
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title [Nível 1] Diagrama de Contexto — Asteroids Multiplayer Local

Person(jogador1, "Jogador 1", "Controla nave ciano com WASD + Q (EMP)")
Person(jogador2, "Jogador 2", "Controla nave amarela com setas + P (EMP)")
Person(jogador3, "Jogador 3", "Controla nave verde com IJKL + Y (EMP)")
Person(jogador4, "Jogador 4", "Controla nave vermelha com teclado numérico + NumEnter (EMP)")

System(jogo, "Asteroids Multiplayer Local", "Jogo de arcade local para 1 a 4 jogadores.\nModos: Solo, Cooperativo, Duelo, Todos vs Todos, Equipes 2v2.\nMecânicas inéditas: Pulsar EMP, Rastro Gravitacional e Sistema de Resgate.")

Rel(jogador1, jogo, "Joga via teclado (controle Tectoy J1)")
Rel(jogador2, jogo, "Joga via teclado (controle Tectoy J2)")
Rel(jogador3, jogo, "Joga via teclado (controle Tectoy J3)")
Rel(jogador4, jogo, "Joga via teclado (controle Tectoy J4)")

@enduml
